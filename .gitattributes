# 모든 텍스트 파일은 LF로 정규화 (Windows ↔ Linux/macOS CRLF 차이 차단)
* text=auto eol=lf

# 소스 코드
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.gradle    text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.sql       text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Gradle wrapper
gradlew     text eol=lf
gradlew.bat text eol=crlf

# 바이너리 (diff 비활성)
*.jar       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.keystore  binary
